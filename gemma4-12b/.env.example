# HuggingFace token. Get one at https://huggingface.co/settings/tokens
#
# The gemma-4-12B-it model is gated; you need:
#   1. A HF account
#   2. To have accepted the Gemma license on
#      https://huggingface.co/google/gemma-4-12B-it
#   3. A token with at least "read" scope
#
# The Makefile auto-loads this file if you `make <target>` from this dir.

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CUDA toolkit path (only needed for `make test-cuda` or `make bucket`).
# Comment out if you only want to run the text-only notebook.
# Linux:   /usr/local/cuda
# Mac:     /usr/local/cuda
# Windows: C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v12.4
# CUDA_HOME=/usr/local/cuda

# Optional: override the source model (default: google/gemma-4-12B-it)
# SOURCE_MODEL=google/gemma-4-12B-it
