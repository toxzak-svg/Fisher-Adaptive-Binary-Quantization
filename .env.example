# Copy this to .env and fill in your actual tokens
# DO NOT commit .env to version control - add it to .gitignore

# Hugging Face API token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# GitHub Personal Access Token (get from https://github.com/settings/tokens)
# Only needed if you want to push directly from Colab/notebook
GH_TOKEN=ghp_your_github_token_here

# Hugging Face model/dataset repository (format: username/repo-name)
HF_REPO_ID=your-username/your-repo
